# ============================================================
# DMTCDRK — Production
# cp .env.example .env  &&  заполни GIT_PUSH_TOKEN
# .env в git не коммитить
# ============================================================

# --- Git (обязательно) ---
GIT_PUSH_TOKEN=

# --- Файлы ---
INPUT_FILE=input.txt
OUTPUT_FILE=output_optimized.txt

# --- DNS over TLS (NextDNS) ---
DNS_OVER_TLS=1
DNS_OVER_TLS_SERVERS=45.90.28.61:YOUR-ID.dns.nextdns.io,45.90.30.61:YOUR-ID.dns.nextdns.io

# --- Daemon: docker compose up -d daemon ---
SCHEDULE_INTERVAL_MINUTES=60
USE_DOMAIN_CACHE=1
RESOLVE_PER_RUN=5000
CACHE_TTL_HOURS=24

# --- Производительность (осторожно: быстрый резолв = бан DNS) ---
CONCURRENCY_LIMIT=1
DELAY=1.0
RESOLVER_TIMEOUT=5.0

# --- Git commit (для sync) ---
GIT_USER_NAME=DMTCDRK
GIT_USER_EMAIL=dmtcdrk@localhost

# --- Прочее ---
GIT_BRANCH=main
LOG_LEVEL=INFO
