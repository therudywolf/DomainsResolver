# ============================================================
# DMTCDRK — пример настроек
# Скопируй: cp .env.example .env  и заполни GIT_PUSH_TOKEN
# .env в git не коммитить
# ============================================================

# --- Git (обязательно для push) ---
GIT_PUSH_TOKEN=

# --- Файлы ввода/вывода ---
INPUT_FILE=input.txt
OUTPUT_FILE=output_optimized.txt

# --- WireGuard: один контейнер под WG, DNS для резолва = из конфига WG (/etc/resolv.conf) ---
WG_CONF=forestserver_DE-DE-578.conf

# --- Daemon ---
SCHEDULE_INTERVAL_MINUTES=60
USE_DOMAIN_CACHE=1
RESOLVE_PER_RUN=5000
CACHE_TTL_HOURS=24

# --- Производительность (быстрый резолв = риск бана) ---
CONCURRENCY_LIMIT=1
DELAY=1.0
RESOLVER_TIMEOUT=5.0

# --- Git commit (sync) ---
GIT_USER_NAME=DMTCDRK
GIT_USER_EMAIL=dmtcdrk@localhost
GIT_BRANCH=main

# --- Прочее ---
LOG_LEVEL=INFO
