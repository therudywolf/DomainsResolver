# Copy to .env and set values. .env is gitignored. Do not commit secrets.

# Input/output
# INPUT_FILE=input.txt
# OUTPUT_FILE=output_optimized.txt
# HASH_FILE=.input_hash

# DNS (keep CONCURRENCY_LIMIT low to avoid rate limits)
# CONCURRENCY_LIMIT=1
# DELAY=0.9
# RESOLVER_TIMEOUT=5.0
# DNS_POOL=8.8.8.8,1.1.1.1,9.9.9.9

# Optional: keep previous output when optimized list is empty
# KEEP_LAST_OUTPUT_IF_EMPTY=1

# Optional: ignore input hash and always run pipeline
# FORCE_RUN=1

# Optional: resolve AAAA (IPv6) in addition to A
# RESOLVE_AAAA=1

# Logging: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Git push (HTTPS). Origin URL restored after push; do not commit token.
# GIT_PUSH_TOKEN=ghp_xxxx...
# GIT_BRANCH=main
# GIT_SIGN_COMMITS=1
# GIT_PUSH_RETRIES=3
# GIT_PUSH_SLEEP=5
