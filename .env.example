# DMTCDRK — скопируй в .env и заполни. В репо не коммитить.

# === Обязательно (для пуша в Git) ===
# Токен: https://github.com/settings/tokens → Generate new token (classic) → repo
GIT_PUSH_TOKEN=

# === По желанию ===
# INPUT_FILE=input.txt
# OUTPUT_FILE=output_optimized.txt
# CONCURRENCY_LIMIT=1
# DELAY=0.9
# GIT_BRANCH=main
# FORCE_RUN=0
# KEEP_LAST_OUTPUT_IF_EMPTY=0
# RESOLVE_AAAA=0
# LOG_LEVEL=INFO
